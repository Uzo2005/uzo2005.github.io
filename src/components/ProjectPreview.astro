---
import OutlineShadow from "./OutlineShadow.astro";
import { Image } from "astro:assets";
interface Props {
  projectName: string;
  projectDescription: string;
  projectPreviewImg: string;
  projectUrl: string;
}

const { projectName, projectDescription, projectPreviewImg, projectUrl } =
  Astro.props;
---

<OutlineShadow>
  <div
    class="bg-yellowLight w-full h-60 md:h-80 p-3 flex flex-col gap-2 justify-between px-5 md:px-10"
  >
    <h2 class="font-semibold text-sm md:text-lg md:mb-4 text-black">
      {projectName}
    </h2>
    <div class="flex justify-between gap-4 w-full h-full">
      <div class="size-40 flex items-start">
        <Image
          src={projectPreviewImg}
          width={500}
          height={500}
          alt="sample_image"
          class="rounded-sm"
        />
      </div>

      <div
        class="h-full overflow-hidden w-full md:w-[80%] flex items-end text-[10px] md:text-base"
      >
        {projectDescription} link is {projectUrl}
      </div>
    </div>
  </div>
</OutlineShadow>
